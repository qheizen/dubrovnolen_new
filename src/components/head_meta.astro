---
import { useTranslations, type Language } from '../i18n/utils';

interface IMeta {
  lang: Language;
}

const {lang} = Astro.props;

const t = useTranslations(lang);
const description = t('manufacturer.description')
const ogdesctiption = t('manufacturer.ogdescription')

---
<meta charset="utf-8" />
    
<meta name="description" content={description}>
<meta name="robots" content="index,contacts,about">
<meta property="og:description" content={ogdesctiption}>
<meta property="og:url" content="http://dubrovnolen.by">
<meta property="og:type" content="website">

<meta name="theme-color" content="#ffffff">
<link rel="icon" type="image/svg" href="/favicon.svg">
<link rel="icon" href="/favicon.ico">